{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel)/plugins/sdd-workflow/scripts/block-dangerous-bash.sh\"",
            "statusMessage": "Checking Bash command"
          }
        ]
      }
    ]
  }
}
